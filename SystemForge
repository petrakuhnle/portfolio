<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="UX analysis and learnability work for System Forge, a SysML v2 modeling tool. Separating what the spec fixes from where design can teach.">
    <title>System Forge · UX Analysis &amp; Learnability — Petra Kühnle</title>
    <style>
        :root{
            --bg:#FBFAF7;
            --bg-raised:#FFFFFF;
            --bg-sunken:#F1EEE7;
            --ink:#2A2824;
            --ink-soft:#4A4641;
            --ink-muted:#6E6A61;
            --ink-faint:#9B968C;
            --hairline:#DBD6CC;
            --hairline-strong:#B8B1A4;
            --accent-neutral:#7A756D;
            --accent-positive:#6B8761;
            --accent-positive-bg:#EEF2EC;
            --accent-warn:#A67849;
            --accent-warn-bg:#F5EEE3;
            --accent-warn-ink:#6E5836;
            --mono:'SF Mono',Menlo,Consolas,monospace;
            --sans:-apple-system,BlinkMacSystemFont,'Inter','Segoe UI',sans-serif;
        }
        *{box-sizing:border-box;}
        body{margin:0;background:var(--bg);color:var(--ink);font-family:var(--sans);font-size:16px;line-height:1.62;-webkit-font-smoothing:antialiased;}
        ::selection{background:var(--ink);color:var(--bg);}
        header,main,footer{max-width:880px;margin:0 auto;padding:0 24px;}
        header{padding-top:52px;}
        header h1{font-size:clamp(26px,4.5vw,36px);font-weight:600;letter-spacing:-0.02em;margin:0 0 12px;line-height:1.15;}
        header p{margin:0 0 8px;color:var(--ink-soft);max-width:46em;}
        header .meta{font-family:var(--mono);font-size:0.78em;color:var(--ink-muted);}
        main{padding-top:16px;padding-bottom:40px;}
        section{margin:36px 0;}
        .section-title{font-size:0.78em;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-muted);margin:0 0 14px;padding-bottom:8px;border-bottom:1px solid var(--hairline);}
        main > section > p{color:var(--ink-soft);max-width:46em;}

        .case-summary{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--hairline);border:1px solid var(--hairline);margin:20px 0;}
        .psi{background:var(--bg-raised);padding:18px;}
        .psi-label{font-family:var(--mono);font-size:0.7em;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink-faint);display:block;margin-bottom:8px;}
        .psi p{margin:0;font-size:0.9em;color:var(--ink-soft);line-height:1.5;}
        .psi strong{color:var(--ink);font-weight:600;}
        .psi.is-impact{background:var(--ink);}
        .psi.is-impact .psi-label{color:var(--hairline-strong);}
        .psi.is-impact p{color:#EDEAE3;}
        .psi.is-impact strong{color:#fff;}

        .role-summary{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin:16px 0;padding:16px;background:var(--bg-sunken);border-left:3px solid var(--accent-neutral);}
        .role-item strong{font-size:0.72em;text-transform:uppercase;letter-spacing:0.5px;color:var(--ink-muted);display:block;margin-bottom:4px;}
        .role-item span{font-size:0.88em;color:var(--ink);}

        .why-card{border:1px solid var(--ink);background:var(--bg-raised);padding:20px 24px;margin:16px 0;}
        .why-card-label{font-family:var(--mono);font-size:0.7em;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--ink);margin-bottom:12px;display:block;}
        .why-card ol{margin:0;padding-left:20px;list-style:decimal;}
        .why-card ol li{font-size:0.92em;margin-bottom:6px;padding-left:4px;color:var(--ink-soft);line-height:1.5;}
        .why-card ol li strong{color:var(--ink);font-weight:600;}

        .design-space-visual{margin:18px 0 8px;padding:24px 20px 16px;background:var(--bg-sunken);border:1px solid var(--hairline);}
        .design-space-visual svg{display:block;width:100%;height:auto;max-width:720px;margin:0 auto;}
        .design-space-caption{text-align:center;font-size:0.82em;color:var(--ink-muted);margin:14px auto 0;max-width:560px;line-height:1.5;}
        .design-space-caption strong{color:var(--accent-positive);font-weight:600;}

        .flow-diagram{background:#fff;border:1px solid var(--hairline);padding:28px 20px;margin:18px 0;}
        .flow-diagram svg{display:block;width:100%;height:auto;max-width:920px;margin:0 auto;}
        .flow-diagram svg text{font-family:var(--sans);}
        .flow-diagram svg .mono{font-family:var(--mono);}
        .flow-caption{text-align:center;font-size:0.82em;color:var(--ink-muted);margin-top:14px;font-style:italic;}

        .learnability-goal{background:var(--accent-positive-bg);border:1px solid var(--hairline);border-left:3px solid var(--accent-positive);padding:20px;margin:16px 0;}
        .learnability-goal h3{font-size:0.9em;font-weight:600;color:var(--accent-positive);margin:0 0 12px;}
        .user-types{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
        .user-type{background:var(--bg-raised);padding:14px;border-left:3px solid var(--accent-positive);}
        .user-type strong{font-size:0.85em;display:block;margin-bottom:4px;color:var(--ink);}
        .user-type p{font-size:0.8em;color:var(--ink-soft);margin:0;line-height:1.5;}

        .process-steps{display:grid;grid-template-columns:repeat(5,1fr);gap:12px;margin:16px 0;}
        .process-step{padding:14px;background:var(--bg-raised);border-top:3px solid var(--hairline);text-align:center;}
        .process-step.complete{border-top-color:var(--accent-positive);}
        .process-step .num{font-family:var(--mono);font-size:0.7em;font-weight:600;color:var(--ink-faint);display:block;margin-bottom:4px;}
        .process-step strong{font-size:0.85em;display:block;margin-bottom:4px;color:var(--ink);}
        .process-step p{font-size:0.75em;color:var(--ink-muted);margin:0;line-height:1.4;}

        .principles-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin:16px 0;}
        .principle-card{display:flex;gap:10px;padding:12px;background:var(--bg-raised);border-left:3px solid var(--accent-neutral);}
        .principle-card.learnability{border-left-color:var(--accent-positive);}
        .principle-num{font-family:var(--mono);font-size:0.75em;font-weight:600;color:var(--ink-faint);min-width:20px;}
        .principle-content strong{font-size:0.85em;color:var(--ink);display:block;margin-bottom:2px;}
        .principle-content p{font-size:0.75em;color:var(--ink-soft);line-height:1.45;margin:0;}
        .principle-source{font-size:0.9em;color:var(--ink-faint);}

        .sources-strip{background:var(--bg-sunken);border:1px solid var(--hairline);border-left:3px solid var(--accent-neutral);padding:14px 16px;margin:16px 0;}
        .sources-strip-label{font-family:var(--mono);font-size:0.7em;font-weight:600;letter-spacing:1.2px;text-transform:uppercase;color:var(--accent-neutral);margin-bottom:8px;}
        .sources-strip-content{font-size:0.82em;color:var(--ink-soft);line-height:1.6;}
        .sources-strip-content strong{color:var(--ink);font-weight:600;}

        .constraint-detail{margin:20px 0;}
        .constraint-detail-header{display:flex;align-items:center;gap:10px;margin-bottom:10px;}
        .constraint-detail-header .label{font-family:var(--mono);font-size:0.68em;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;padding:4px 10px;}
        .constraint-detail-header .label.fixed{background:var(--bg-sunken);color:var(--ink-muted);}
        .constraint-detail-header .label.flexible{background:var(--accent-positive-bg);color:var(--accent-positive);}
        .constraint-detail-header h4{font-size:0.9em;font-weight:600;color:var(--ink);margin:0;}
        .constraint-table{width:100%;border-collapse:collapse;font-size:0.82em;border:1px solid var(--hairline);}
        .constraint-table thead{background:var(--bg-sunken);}
        .constraint-table.flexible thead{background:var(--accent-positive-bg);}
        .constraint-table th{text-align:left;padding:10px 12px;font-size:0.75em;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;color:var(--ink-muted);border-bottom:1px solid var(--hairline);}
        .constraint-table.flexible th{color:var(--accent-positive);}
        .constraint-table td{padding:9px 12px;border-bottom:1px solid var(--hairline);color:var(--ink-soft);vertical-align:top;}
        .constraint-table tr:last-child td{border-bottom:none;}
        .constraint-table td:first-child{font-weight:500;color:var(--ink);width:35%;}
        .constraint-boundary-note{background:var(--accent-warn-bg);border-left:3px solid var(--accent-warn);padding:12px 14px;margin:16px 0;font-size:0.85em;color:var(--accent-warn-ink);line-height:1.55;}
        .constraint-boundary-note strong{color:var(--accent-warn);}

        .screenshot-annotation{border:1px solid var(--hairline);margin:20px 0;background:var(--bg-raised);}
        .screenshot-header{padding:12px 16px;background:var(--bg-sunken);border-bottom:1px solid var(--hairline);font-size:0.85em;font-weight:600;color:var(--ink);}
        .screenshot-body{padding:20px;}
        .screenshot-image{margin-bottom:16px;text-align:center;}
        .screenshot-image img{max-width:100%;border:1px solid var(--hairline);border-radius:4px;}
        .annotation-list{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
        .annotation-item{padding:12px;background:var(--bg-raised);border-left:3px solid var(--accent-neutral);}
        .annotation-item.strength{border-left-color:var(--accent-positive);}
        .annotation-item.consideration{border-left-color:var(--accent-warn);}
        .annotation-item strong{font-size:0.8em;display:block;margin-bottom:4px;color:var(--ink);}
        .annotation-item p{font-size:0.78em;color:var(--ink-soft);margin:0;line-height:1.5;}
        .annotation-item .tag{display:inline-block;font-family:var(--mono);font-size:0.68em;padding:2px 6px;background:var(--bg-sunken);color:var(--ink-muted);margin-top:6px;}

        .recommendations-box{margin:8px 0 0;padding:20px 22px;background:var(--accent-positive-bg);border:1px solid var(--hairline);border-left:3px solid var(--accent-positive);}
        .recommendations-box h3{font-size:0.95em;font-weight:600;color:var(--accent-positive);margin:0 0 6px;}
        .recommendations-intro{font-size:0.85em;color:var(--ink-soft);margin-bottom:14px;}
        .recommendations-list{margin:0;padding-left:20px;list-style:decimal;}
        .recommendations-list li{font-size:0.85em;color:var(--ink-soft);line-height:1.55;margin-bottom:10px;}
        .recommendations-list li strong{color:var(--ink);font-weight:600;}

        .ai-notes{display:grid;gap:12px;margin:16px 0;}
        .ai-note{background:var(--bg-raised);border:1px solid var(--hairline);border-left:3px solid var(--accent-neutral);padding:16px 18px;}
        .ai-note strong{color:var(--ink);font-weight:600;}
        .ai-note p{margin:0;font-size:0.88em;color:var(--ink-soft);line-height:1.55;}

        .reflection{background:var(--bg-sunken);border:1px solid var(--hairline);padding:16px;margin:12px 0;}
        .reflection p{margin:0;font-size:0.87em;color:var(--ink-soft);line-height:1.55;}
        .reflection strong{color:var(--ink);}

        .resources-list{list-style:none;margin:14px 0 0;padding:0;border-top:1px solid var(--hairline);}
        .resources-list li{display:flex;gap:16px;padding:11px 2px;border-bottom:1px solid var(--hairline);font-size:0.86em;}
        .resources-list .r-name{font-weight:600;color:var(--ink);min-width:170px;}
        .resources-list .r-desc{color:var(--ink-soft);}

        .tech-list{display:flex;flex-wrap:wrap;gap:8px;margin:8px 0;}
        .tech-tag{font-family:var(--mono);font-size:0.75em;padding:5px 11px;background:var(--bg-sunken);border:1px solid var(--hairline);color:var(--ink-muted);}

        nav{display:flex;justify-content:space-between;gap:16px;border-top:1px solid var(--hairline);padding-top:20px;margin-top:36px;}
        nav a{font-family:var(--mono);font-size:0.82em;color:var(--ink-muted);text-decoration:none;}
        nav a:hover{color:var(--ink);}
        footer{border-top:1px solid var(--hairline);padding-top:18px;padding-bottom:40px;color:var(--ink-faint);font-size:0.8em;}

        @media (max-width:768px){
            .case-summary{grid-template-columns:1fr;}
            .role-summary{grid-template-columns:1fr 1fr;}
            .principles-grid{grid-template-columns:1fr;}
            .process-steps{grid-template-columns:repeat(2,1fr);}
            .user-types{grid-template-columns:1fr;}
            .annotation-list{grid-template-columns:1fr;}
            .constraint-table{font-size:0.78em;}
            .constraint-table td,.constraint-table th{padding:8px 10px;}
            .resources-list li{flex-direction:column;gap:2px;}
            .resources-list .r-name{min-width:0;}
        }
    </style>
</head>
<body class="project wide">
    <header>
        <h1>⬠ System Forge · UX Analysis &amp; Learnability</h1>
        <p>Making SysML v2 learnable through UX.</p>
        <p class="meta">2026 · UX input for a side project by Cauê Napier, Systems Engineer at Swedish Space Corporation</p>
    </header>
    <main>

        <section class="case-summary">
            <div class="psi">
                <span class="psi-label">Problem</span>
                <p>SysML v2 is powerful but hard to learn without taking a course first. The spec hands every presentation and interaction choice to the tool.</p>
            </div>
            <div class="psi">
                <span class="psi-label">Solution</span>
                <p>The brief was to review the screens. I widened it into a learnability foundation: ten design principles, a map of what the spec fixes versus what the tool controls, and an interface audit with a ranked roadmap.</p>
            </div>
            <div class="psi is-impact">
                <span class="psi-label">Impact</span>
                <p>Principles, an audit, and a roadmap ranked by leverage. <strong>Foundations that outlast any single screen</strong>, ordered so the most downstream work gets unblocked first. Ongoing.</p>
            </div>
        </section>

        <section>
            <div class="role-summary">
                <div class="role-item">
                    <strong>Role</strong>
                    <span>UX analysis · design principles · solution sketches</span>
                </div>
                <div class="role-item">
                    <strong>Duration</strong>
                    <span>Ongoing, 2026 to present</span>
                </div>
                <div class="role-item">
                    <strong>Deliverables</strong>
                    <span>Analysis · principles · learnability recommendations</span>
                </div>
                <div class="role-item">
                    <strong>Context</strong>
                    <span>SysML v2 released in 2025. It adds textual and graphic notation.</span>
                </div>
            </div>
        </section>

        <section>
            <h2 class="section-title">Why this case matters</h2>
            <div class="why-card">
                <span class="why-card-label">Design-engineering signal</span>
                <ol>
                    <li><strong>Widened the scope.</strong> The brief was to review the screens. The outcome was principles, an audit, and a roadmap. Principles outlast screens.</li>
                    <li><strong>Designed inside a specification.</strong> I separated what SysML v2 fixes from what the tooling can change. That is a rare skill in enterprise software.</li>
                    <li><strong>Domain literacy in MBSE.</strong> SysML v2, systems-of-systems, and expert workflows, rather than generic frontend work.</li>
                </ol>
            </div>
        </section>

        <section>
            <h2 class="section-title">Problem</h2>
            <p>The goal is to make SysML v2 modeling learnable without a course first. The spec fixes element semantics and notation. Presentation and interaction are left to each tool. So every decision sits on one side of a line. Either the standard requires it, or the tool can change it.</p>

            <div class="design-space-visual">
                <svg viewBox="0 0 720 260" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Diagram showing SysML v2 specification on the left (element types, relationships, notation, diagram types, syntax) and the tool design space on the right (color, layout, navigation, tooltips, filtering, search, edge routing, labels, animation).">
                    <rect x="20" y="30" width="300" height="200" rx="4" fill="#efece5" stroke="#d9d4ca" stroke-width="1.5"/>
                    <text x="170" y="55" text-anchor="middle" font-family="Inter, -apple-system, Segoe UI, sans-serif" font-size="10" font-weight="600" letter-spacing="1.2" fill="#7a756d">FIXED BY SPECIFICATION</text>
                    <text x="170" y="72" text-anchor="middle" font-family="Inter, -apple-system, Segoe UI, sans-serif" font-size="12" font-weight="500" fill="#2a2824">SysML v2 semantics</text>
                    <g font-family="Inter, -apple-system, Segoe UI, sans-serif" font-size="10" fill="#4a4641">
                        <rect x="40" y="95" width="100" height="24" rx="12" fill="#fbfaf7" stroke="#d9d4ca" stroke-width="1"/>
                        <text x="90" y="111" text-anchor="middle">Element types</text>
                        <rect x="150" y="95" width="150" height="24" rx="12" fill="#fbfaf7" stroke="#d9d4ca" stroke-width="1"/>
                        <text x="225" y="111" text-anchor="middle">Relationship semantics</text>
                        <rect x="40" y="130" width="120" height="24" rx="12" fill="#fbfaf7" stroke="#d9d4ca" stroke-width="1"/>
                        <text x="100" y="146" text-anchor="middle">Notation shapes</text>
                        <rect x="170" y="130" width="130" height="24" rx="12" fill="#fbfaf7" stroke="#d9d4ca" stroke-width="1"/>
                        <text x="235" y="146" text-anchor="middle">Compartment rules</text>
                        <rect x="40" y="165" width="110" height="24" rx="12" fill="#fbfaf7" stroke="#d9d4ca" stroke-width="1"/>
                        <text x="95" y="181" text-anchor="middle">Diagram types</text>
                        <rect x="160" y="165" width="130" height="24" rx="12" fill="#fbfaf7" stroke="#d9d4ca" stroke-width="1"/>
                        <text x="225" y="181" text-anchor="middle">Textual syntax</text>
                    </g>
                    <text x="170" y="215" text-anchor="middle" font-family="Inter, -apple-system, Segoe UI, sans-serif" font-size="10" font-style="italic" fill="#7a756d">Interoperable across tools</text>
                    <line x1="340" y1="50" x2="340" y2="230" stroke="#a67849" stroke-width="2" stroke-dasharray="4,4"/>
                    <text x="340" y="22" text-anchor="middle" font-family="Inter, -apple-system, Segoe UI, sans-serif" font-size="9" font-weight="600" fill="#a67849">boundary</text>
                    <rect x="360" y="30" width="340" height="200" rx="4" fill="#eef2ec" stroke="#b8b1a4" stroke-width="1.5"/>
