                    <text x="530" y="72" text-anchor="middle" font-family="Inter, -apple-system, Segoe UI, sans-serif" font-size="12" font-weight="500" fill="#2a2824">Tool presentation &amp; interaction</text>
                    <g font-family="Inter, -apple-system, Segoe UI, sans-serif" font-size="10" fill="#6b8761">
                        <rect x="380" y="95" width="70" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="415" y="111" text-anchor="middle">Color</text>
                        <rect x="460" y="95" width="70" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="495" y="111" text-anchor="middle">Layout</text>
                        <rect x="540" y="95" width="90" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="585" y="111" text-anchor="middle">Navigation</text>
                        <rect x="380" y="130" width="80" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="420" y="146" text-anchor="middle">Tooltips</text>
                        <rect x="470" y="130" width="90" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="515" y="146" text-anchor="middle">Filtering</text>
                        <rect x="570" y="130" width="80" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="610" y="146" text-anchor="middle">Search</text>
                        <rect x="380" y="165" width="100" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="430" y="181" text-anchor="middle">Edge routing</text>
                        <rect x="490" y="165" width="80" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="530" y="181" text-anchor="middle">Labels</text>
                        <rect x="580" y="165" width="90" height="24" rx="12" fill="#fbfaf7" stroke="#b8b1a4" stroke-width="1"/>
                        <text x="625" y="181" text-anchor="middle">Animation</text>
                    </g>
                    <text x="530" y="215" text-anchor="middle" font-family="Inter, -apple-system, Segoe UI, sans-serif" font-size="10" font-style="italic" fill="#4a4641">Where learnability is designed in</text>
                </svg>
                <p class="design-space-caption">The standard fixes the semantics. Everything else is the <strong>tool design space</strong>.</p>
            </div>
        </section>

        <section>
            <h2 class="section-title">Framing &amp; reframing</h2>
            <div class="flow-diagram">
                <svg viewBox="0 0 920 170" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Reframe flow: initial brief to reframe to outcome">
                    <text x="155" y="32" text-anchor="middle" font-size="9" fill="#999" class="mono" letter-spacing="1.5">01 — BRIEF</text>
                    <text x="460" y="32" text-anchor="middle" font-size="9" fill="#999" class="mono" letter-spacing="1.5">02 — REFRAME</text>
                    <text x="765" y="32" text-anchor="middle" font-size="9" fill="#999" class="mono" letter-spacing="1.5">03 — OUTCOME</text>

                    <rect x="20" y="50" width="270" height="86" fill="#fff" stroke="#000" stroke-width="1.2"/>
                    <text x="155" y="80" text-anchor="middle" font-size="13" font-weight="500" fill="#000">"Review screens.</text>
                    <text x="155" y="98" text-anchor="middle" font-size="13" font-weight="500" fill="#000">Improve layouts."</text>
                    <text x="155" y="120" text-anchor="middle" font-size="10" fill="#666" font-style="italic">Original ask</text>

                    <line x1="295" y1="93" x2="320" y2="93" stroke="#000" stroke-width="1.2"/>
                    <polygon points="320,88 330,93 320,98" fill="#000"/>

                    <rect x="335" y="50" width="250" height="86" fill="#fff" stroke="#000" stroke-width="1.2"/>
                    <text x="460" y="78" text-anchor="middle" font-size="12" font-weight="500" fill="#000">Define principles first.</text>
                    <text x="460" y="96" text-anchor="middle" font-size="12" font-weight="500" fill="#000">Learnability as the lens.</text>
